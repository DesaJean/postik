{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Postik",
  "version": "0.1.3",
  "identifier": "com.postik.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Floating sticky notes with per-window timers",
    "longDescription": "Postik is a multi-window sticky notes app: each note is a real, independent OS window with its own timer, color, opacity, and always-on-top toggle.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
